<Application x:Class="Cloudfiles.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Cloudfiles.App.Views"
             xmlns:viewmodels="clr-namespace:Cloudfiles.App.ViewModels"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ViewModel to View mappings -->
            <DataTemplate DataType="{x:Type viewmodels:FileListViewModel}">
                <views:FileListView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:UploadViewModel}">
                <views:UploadView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
