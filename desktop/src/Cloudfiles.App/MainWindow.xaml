<Window x:Class="Cloudfiles.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:Cloudfiles.App.Views"
        xmlns:viewmodels="clr-namespace:Cloudfiles.App.ViewModels"
        Title="Cloudfiles"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="4"
                            GlassFrameThickness="0"
                            CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#181825" CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title Bar Area -->
                <StackPanel Grid.Row="0" Margin="16,50,16,20">
                    <TextBlock Text="☁ Cloudfiles"
                               Foreground="#cdd6f4"
                               FontSize="20"
                               FontWeight="Bold" />
                    <TextBlock Text="Cloudflare Pages 管理工具"
                               Foreground="#6c7086"
                               FontSize="11"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="8,0">
                    <Button Content="📁 部署"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToFilesCommand}"
                            Tag="Files" />
                    <Button Content="⬆ 上传"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToUploadCommand}"
                            Tag="Upload" />
                    <Button Content="⚙ 设置"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToSettingsCommand}"
                            Tag="Settings" />
                </StackPanel>

                <!-- Status -->
                <StackPanel Grid.Row="2" Margin="16,0,16,16">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#6c7086"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Window Controls -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="─" Style="{StaticResource TitleBarButton}" Command="{Binding MinimizeCommand}" />
                <Button Content="□" Style="{StaticResource TitleBarButton}" Command="{Binding MaximizeCommand}" />
                <Button Content="✕" Style="{StaticResource TitleBarCloseButton}" Command="{Binding CloseCommand}" />
            </StackPanel>

            <!-- Page Content -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="0" />
        </Grid>
    </Grid>
</Window>
