<UserControl x:Class="Cloudfiles.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1e1e2e">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Settings"
                       Foreground="#cdd6f4" FontSize="24" FontWeight="Bold" Margin="0,0,0,24" />

            <!-- API Token -->
            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <TextBlock Text="API Token" Foreground="#a6adc8" FontSize="14" Margin="0,0,0,8" />
                <PasswordBox x:Name="ApiTokenBox"
                             Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                             Padding="10,8" FontSize="14"
                             PasswordChanged="ApiTokenBox_PasswordChanged" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Verify Token" Command="{Binding VerifyTokenCommand}"
                            Style="{StaticResource ActionButton}" Margin="0" />
                    <TextBlock Text="{Binding VerificationMessage}"
                               Foreground="{Binding IsTokenValid, Converter={StaticResource BoolToColorConverter}}"
                               FontSize="13" VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- Account ID -->
            <StackPanel Grid.Row="2" Margin="0,0,0,20">
                <TextBlock Text="Account ID" Foreground="#a6adc8" FontSize="14" Margin="0,0,0,8" />
                <TextBox Text="{Binding AccountId, UpdateSourceTrigger=PropertyChanged}"
                         Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                         Padding="10,8" FontSize="14" />
            </StackPanel>

            <!-- Project Selection -->
            <StackPanel Grid.Row="3" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Project" Foreground="#a6adc8" FontSize="14" VerticalAlignment="Center" />
                    <Button Content="Load Projects" Command="{Binding LoadProjectsCommand}"
                            Style="{StaticResource ActionButton}" Margin="12,0,0,0" Padding="8,4" />
                </StackPanel>
                <ComboBox ItemsSource="{Binding Projects}"
                          SelectedItem="{Binding SelectedProject}"
                          DisplayMemberPath="Name"
                          Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                          Padding="10,8" FontSize="14" />
            </StackPanel>

            <!-- Chunk Size -->
            <StackPanel Grid.Row="4" Margin="0,0,0,20">
                <TextBlock Text="Chunk Size (MB)" Foreground="#a6adc8" FontSize="14" Margin="0,0,0,8" />
                <TextBox Text="{Binding ChunkSizeMB, UpdateSourceTrigger=PropertyChanged}"
                         Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                         Padding="10,8" FontSize="14" />
            </StackPanel>

            <!-- Save Button -->
            <Button Grid.Row="5" Content="💾 Save Settings"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource AccentButton}"
                    HorizontalAlignment="Left" />

            <!-- Info -->
            <Border Grid.Row="6" Background="#313244" CornerRadius="8" Padding="16" Margin="0,24,0,0">
                <StackPanel>
                    <TextBlock Text="How to get your API Token &amp; Account ID"
                               Foreground="#89b4fa" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" LineHeight="20">
                        <Run Text="1. Go to https://dash.cloudflare.com/profile/api-tokens" /><LineBreak />
                        <Run Text="2. Create a token with Cloudflare Pages edit permissions" /><LineBreak />
                        <Run Text="3. Your Account ID is found in the Cloudflare dashboard URL" /><LineBreak />
                        <Run Text="4. Create a Pages project first, then select it here" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
