<UserControl x:Class="Cloudfiles.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1e1e2e">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="设置"
                       Foreground="#cdd6f4" FontSize="24" FontWeight="Bold" Margin="0,0,0,24" />

            <!-- API Token -->
            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <TextBlock Text="API Token" Foreground="#a6adc8" FontSize="14" Margin="0,0,0,8" />
                <PasswordBox x:Name="ApiTokenBox"
                             Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                             Padding="10,8" FontSize="14"
                             PasswordChanged="ApiTokenBox_PasswordChanged" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="验证 Token" Command="{Binding VerifyTokenCommand}"
                            Style="{StaticResource ActionButton}" Margin="0" />
                    <TextBlock Text="{Binding VerificationMessage}"
                               Foreground="{Binding IsTokenValid, Converter={StaticResource BoolToColorConverter}}"
                               FontSize="13" VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- Account ID -->
            <StackPanel Grid.Row="2" Margin="0,0,0,20">
                <TextBlock Text="Account ID" Foreground="#a6adc8" FontSize="14" Margin="0,0,0,8" />
                <TextBox Text="{Binding AccountId, UpdateSourceTrigger=PropertyChanged}"
                         Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                         Padding="10,8" FontSize="14" />
            </StackPanel>

            <!-- Main Project Selection -->
            <StackPanel Grid.Row="3" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="主项目" Foreground="#a6adc8" FontSize="14" VerticalAlignment="Center" />
                    <Button Content="加载项目" Command="{Binding LoadProjectsCommand}"
                            Style="{StaticResource ActionButton}" Margin="12,0,0,0" Padding="8,4" />
                </StackPanel>
                <ComboBox ItemsSource="{Binding Projects}"
                          SelectedItem="{Binding SelectedProject}"
                          DisplayMemberPath="Name"
                          Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                          Padding="10,8" FontSize="14" />
                <TextBlock Text="存储 main.json 文件索引的项目" Foreground="#6c7086" FontSize="12" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Data Project Selection -->
            <StackPanel Grid.Row="4" Margin="0,0,0,20">
                <TextBlock Text="数据项目" Foreground="#a6adc8" FontSize="14" Margin="0,0,0,8" />
                <ComboBox ItemsSource="{Binding Projects}"
                          SelectedItem="{Binding SelectedDataProject}"
                          DisplayMemberPath="Name"
                          Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                          Padding="10,8" FontSize="14" />
                <TextBlock Text="存储文件分块数据的项目" Foreground="#6c7086" FontSize="12" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Chunk Size -->
            <StackPanel Grid.Row="5" Margin="0,0,0,20">
                <TextBlock Text="分块大小 (MB)" Foreground="#a6adc8" FontSize="14" Margin="0,0,0,8" />
                <TextBox Text="{Binding ChunkSizeMB, UpdateSourceTrigger=PropertyChanged}"
                         Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                         Padding="10,8" FontSize="14" />
            </StackPanel>

            <!-- Save Button -->
            <Button Grid.Row="6" Content="保存设置"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource AccentButton}"
                    HorizontalAlignment="Left" />

            <!-- Info -->
            <Border Grid.Row="7" Background="#313244" CornerRadius="8" Padding="16" Margin="0,24,0,0">
                <StackPanel>
                    <TextBlock Text="如何获取 API Token 和 Account ID"
                               Foreground="#89b4fa" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap" Foreground="#a6adc8" FontSize="13" LineHeight="20">
                        <Run Text="1. 访问 https://dash.cloudflare.com/profile/api-tokens" /><LineBreak />
                        <Run Text="2. 创建具有 Cloudflare Pages 编辑权限的 Token" /><LineBreak />
                        <Run Text="3. Account ID 可在 Cloudflare 控制台 URL 中找到" /><LineBreak />
                        <Run Text="4. 先创建两个 Pages 项目（主项目+数据项目），然后在此选择" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
