<UserControl x:Class="Cloudfiles.App.Views.UploadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1e1e2e">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="上传文件"
                   Foreground="#cdd6f4" FontSize="24" FontWeight="Bold" Margin="0,0,0,16" />

        <!-- Remote Path Prefix -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="远程路径前缀:"
                       Foreground="#a6adc8" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBox Grid.Column="1"
                     Text="{Binding RemotePathPrefix, UpdateSourceTrigger=PropertyChanged}"
                     Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                     Padding="10,8" FontSize="14" VerticalContentAlignment="Center" />
        </Grid>

        <!-- Browse Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="📁 选择文件"
                    Command="{Binding BrowseFilesCommand}"
                    Style="{StaticResource ActionButton}"
                    HorizontalAlignment="Left" />
            <Button Content="📂 选择目录"
                    Command="{Binding BrowseDirectoryCommand}"
                    Style="{StaticResource ActionButton}"
                    HorizontalAlignment="Left" />
        </StackPanel>

        <!-- File List -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding UploadItems}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Background="Transparent"
                  BorderBrush="#45475a"
                  Foreground="#cdd6f4"
                  RowBackground="#1e1e2e"
                  AlternatingRowBackground="#181825"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#313244">
            <DataGrid.Columns>
                <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="*" />
                <DataGridTextColumn Header="大小" Binding="{Binding FormattedSize}" Width="100" />
                <DataGridTextColumn Header="远程路径" Binding="{Binding RemotePath}" Width="300" />
                <DataGridTemplateColumn Header="操作" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" Foreground="#f38ba8" BorderThickness="0"
                                    FontSize="14" Cursor="Hand" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Upload Actions -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Progress -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <ProgressBar Value="{Binding UploadProgress}" Maximum="100"
                             Height="6" Foreground="#89b4fa" Background="#313244"
                             Visibility="{Binding IsUploading, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#a6adc8" FontSize="13" Margin="0,4,0,0" />
            </StackPanel>

            <Button Grid.Column="1" Content="⬆ 全部上传"
                    Command="{Binding UploadAllCommand}"
                    Style="{StaticResource AccentButton}" />
        </Grid>
    </Grid>
</UserControl>
